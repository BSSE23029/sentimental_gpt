        <mxCell id="Zet76qL6K-UuKe0f87bM-149" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" value="DP_IDN: Functional Composition of Architectural Experts" vertex="1">
          <mxGeometry height="30" width="530" x="11110" y="440" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-150" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;1. Discrete to Continuous Mapping&lt;/b&gt;&lt;br&gt;$$\mathbf{E} = \text{Embed}(\text{indices})$$&lt;br&gt;$$\mathbf{E} \in \mathbb{R}^{L \times D}$$&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;[Sequence Length, 128 Dims]&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="220" x="11264" y="490" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-151" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;2. CNN Perspective (Signal Extraction)&lt;/b&gt;&lt;br&gt;$$\mathbf{h}_{cnn} = \sigma(\mathbf{W} * \text{permute}(\mathbf{E}))$$&lt;br&gt;&lt;br&gt;&lt;i&gt;Code Note:&lt;/i&gt; Flipped to [D x L] so the&lt;br&gt;sliding window treats D as &quot;Channels&quot;" vertex="1">
          <mxGeometry height="100" width="250" x="11249" y="620" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-152" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;3. BiLSTM Perspective (Sequential Flow)&lt;/b&gt;&lt;br&gt;$$\mathbf{h}_{lstm} = [ \overrightarrow{f}(h_{cnn}) \oplus \overleftarrow{f}(h_{cnn}) ]$$&lt;br&gt;$$\mathbf{h}_{lstm} \in \mathbb{R}^{L \times 256}$$&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#cc6600&quot;&gt;Dimensionality Doubling: 128 forward + 128 back&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="280" x="11234" y="760" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-153" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;4. Self-Attention (Relational Topology)&lt;/b&gt;&lt;br&gt;$$Q=K=V = h_{lstm}$$&lt;br&gt;$$\mathbf{A} = \text{Softmax}(\frac{h h^T}{\sqrt{d}})h$$&lt;br&gt;&lt;br&gt;Calculates inter-word covariance of the flow." vertex="1">
          <mxGeometry height="100" width="250" x="11249" y="910" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-154" parent="1" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;5. Global Projection (The Centroid)&lt;/b&gt;&lt;br&gt;$$\mathbf{y} = \text{Mean}(\mathbf{A}, \text{dim}=1)$$&lt;br&gt;$$\mathbb{R}^{L \times 256} \to \mathbb{R}^{256}$$&lt;br&gt;&lt;br&gt;Collapsing L words into one sequence identity." vertex="1">
          <mxGeometry height="90" width="280" x="11234" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-155" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" value="&lt;b&gt;6. Scalar Output&lt;/b&gt;&lt;br&gt;$$\hat{P} = \text{Sigmoid}(W \mathbf{y} + b)$$&lt;br&gt;Final verdict in [0, 1]" vertex="1">
          <mxGeometry height="70" width="200" x="11274" y="1170" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-156" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-150" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-151" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-157" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-151" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-152" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-158" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-152" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-153" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-159" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-153" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-154" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-160" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-154" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-155" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-161" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Math Trick: Dimensional Handshake&lt;/b&gt;&lt;br&gt;We flip axes because the CNN expects&lt;br&gt;sequence dimensions like a spatial&lt;br&gt;grid, while the LSTM/Attention expects&lt;br&gt;them like a timeline." vertex="1">
          <mxGeometry height="110" width="220" x="11540" y="590" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-162" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;The Stacked Merge&lt;/b&gt;&lt;br&gt;Instead of merging &lt;br&gt;parallel outputs, this &lt;br&gt;code &lt;b&gt;refines&lt;/b&gt; the signal.&lt;br&gt;&lt;br&gt;Embed &lt;font color=&quot;#006600&quot;&gt;[Raw]&lt;/font&gt; &lt;br&gt;→ CNN &lt;font color=&quot;#006600&quot;&gt;[Local]&lt;/font&gt;&lt;br&gt;→ LSTM &lt;font color=&quot;#006600&quot;&gt;[Flow]&lt;/font&gt;&lt;br&gt;→ Attention &lt;font color=&quot;#006600&quot;&gt;[Logic]&lt;/font&gt;" vertex="1">
          <mxGeometry height="175" width="180" x="11010" y="745" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-163" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Dimensional Collapse&lt;/b&gt;&lt;br&gt;Without this &lt;i&gt;mean&lt;/i&gt;, the&lt;br&gt;model would produce an&lt;br&gt;answer for every word.&lt;br&gt;We crush the words (L)&lt;br&gt;to find the average &lt;br&gt;energy of the sentence." vertex="1">
          <mxGeometry height="130" width="190" x="11540" y="1040" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-164" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" value="The Centroid Mapping: From Sequence to Verdict" vertex="1">
          <mxGeometry height="30" width="440" x="12500" y="360" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-165" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;Attention Matrix Output&lt;/b&gt;&lt;br&gt;$$\mathbf{M} \in \mathbb{R}^{128 \times 256}$$&lt;br&gt;[128 Words, each a 256-dim vector]" vertex="1">
          <mxGeometry height="70" width="270" x="12589" y="410" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-166" parent="1" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;The Projection (Centroid Operation)&lt;/b&gt;&lt;br&gt;$$\mathbf{y} = \frac{1}{128} \sum_{i=1}^{128} \text{word}_i$$&lt;br&gt;&lt;br&gt;Finding the geometric center of&lt;br&gt;the sequence in Latent Space." vertex="1">
          <mxGeometry height="110" width="300" x="12574" y="520" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-167" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;Sentence Identity Vector&lt;/b&gt;&lt;br&gt;$$\mathbf{v} \in \mathbb{R}^{1 \times 256}$$&lt;br&gt;The &quot;DNA&quot; of the prompt." vertex="1">
          <mxGeometry height="60" width="220" x="12614" y="670" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-168" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Classification Head (Linear Mapping)&lt;/b&gt;&lt;br&gt;$$z = \mathbf{w}^T \mathbf{v} + b$$&lt;br&gt;&lt;br&gt;Projecting the vector onto a&lt;br&gt;1D Decision Axis." vertex="1">
          <mxGeometry height="90" width="240" x="12604" y="770" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-169" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Sigmoid Threshold&lt;/b&gt;&lt;br&gt;$$P = \frac{1}{1 + e^{-z}}$$&lt;br&gt;&lt;br&gt;Mapping the verdict into&lt;br&gt;the probability set [0, 1]." vertex="1">
          <mxGeometry height="150" width="150" x="12649" y="900" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-170" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1" value="&lt;b&gt;Final Prediction&lt;/b&gt;&lt;br&gt;Score &amp;gt; 0.5 ? &lt;font color=&quot;#cc0000&quot;&gt;ATTACK&lt;/font&gt; : &lt;font color=&quot;#009900&quot;&gt;SAFE&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="210" x="12619" y="1090" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-171" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-165" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-166" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-172" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-166" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-167" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-173" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-167" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-168" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-174" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-168" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-169" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-175" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-169" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-170" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-176" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;The Centroid Logic&lt;/b&gt;&lt;br&gt;This is a &lt;b&gt;Many-to-One&lt;/b&gt; mapping.&lt;br&gt;By taking the mean, the model&lt;br&gt;ignores WHERE the malicious&lt;br&gt;word is, and focuses on&lt;br&gt;IF the malicious energy&lt;br&gt;exists in the sentence.&lt;br&gt;&lt;br&gt;Rank: 2 → Rank: 1" vertex="1">
          <mxGeometry height="190" width="180" x="12370" y="490" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-177" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Geometric Decision&lt;/b&gt;&lt;br&gt;The Linear layer defines a&lt;br&gt;&lt;b&gt;Hyperplane&lt;/b&gt; in $\mathbb{R}^{256}$.&lt;br&gt;Safe centroids fall on one&lt;br&gt;side; Attack centroids&lt;br&gt;fall on the other." vertex="1">
          <mxGeometry height="140" width="190" x="12900" y="770" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-178" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" value="The Embedding Algorithm: Discrete Sets to Continuous Manifolds" vertex="1">
          <mxGeometry height="30" width="550" x="1140" y="3460" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-179" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;1. Discrete Symbol Space&lt;/b&gt;&lt;br&gt;String: &quot;Ignore previous rules&quot;&lt;br&gt;&lt;br&gt;$$\mathcal{V} = \{w_1, w_2, \dots, w_n\}$$" vertex="1">
          <mxGeometry height="80" width="220" x="1310" y="3510" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-180" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;2. Tokenization (Coordinate Mapping)&lt;/b&gt;&lt;br&gt;Mapping symbols to integer indices.&lt;br&gt;&lt;br&gt;$$\mathbf{x} \in \mathbb{Z}^{L}$$&lt;br&gt;e.g., [101, 7543, 2301, 102]" vertex="1">
          <mxGeometry height="90" width="240" x="1300" y="3630" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-181" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;3. The Embedding Matrix (The Concept Basis)&lt;/b&gt;&lt;br&gt;&lt;br&gt;$$\mathbf{W}_e \in \mathbb{R}^{|\mathcal{V}| \times d}$$&lt;br&gt;&lt;br&gt;Each row $i$ is a learned vector representing the&lt;br&gt;mathematical &quot;meaning&quot; of word $i$ in $d$ dimensions." vertex="1">
          <mxGeometry height="110" width="340" x="1250" y="3760" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-182" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;4. Linear Projection (Look-up Table)&lt;/b&gt;&lt;br&gt;Extracting the specific concept vectors for the indices in $\mathbf{x}$.&lt;br&gt;&lt;br&gt;$$\mathbf{E} = \text{SelectRows}(\mathbf{W}_e, \mathbf{x})$$" vertex="1">
          <mxGeometry height="90" width="250" x="1295" y="3910" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-183" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;5. Continuous Feature Matrix&lt;/b&gt;&lt;br&gt;$$\mathbf{E} \in \mathbb{R}^{L \times d}$$&lt;br&gt;&lt;br&gt;The prompt is now a sequence of points in space.&lt;br&gt;Ready for Linear Algebra / Convolutions." vertex="1">
          <mxGeometry height="90" width="260" x="1290" y="4040" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-184" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-179" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-180" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-185" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-180" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-181" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-186" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-181" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-182" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-187" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-182" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-183" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-188" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;The Math Perspective&lt;/b&gt;&lt;br&gt;If $\mathbf{x}_i$ is a one-hot vector&lt;br&gt;(a basis vector in $|\mathcal{V}|$ space),&lt;br&gt;the embedding is a dot product:&lt;br&gt;&lt;br&gt;$$\mathbf{v}_i = \mathbf{x}_i \cdot \mathbf{W}_e$$&lt;br&gt;&lt;br&gt;It maps a sparse high-dim space&lt;br&gt;to a dense low-dim manifold." vertex="1">
          <mxGeometry height="180" width="200" x="1040" y="3720" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-189" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Geometric Interpretation&lt;/b&gt;&lt;br&gt;Words like &lt;i&gt;&quot;Ignore&quot;&lt;/i&gt; and &lt;br&gt;&lt;i&gt;&quot;Forget&quot;&lt;/i&gt; will have learned&lt;br&gt;vectors that point in a &lt;br&gt;similar direction (high cosine&lt;br&gt;similarity) in $\mathbb{R}^d$." vertex="1">
          <mxGeometry height="130" width="190" x="1600" y="4000" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-190" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" value="Algorithm: 1D Convolution (Local Feature Extraction)" vertex="1">
          <mxGeometry height="30" width="500" x="2355" y="3440" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-191" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;1. Input Matrix (Embedding)&lt;/b&gt;&lt;br&gt;$$\mathbf{E} \in \mathbb{R}^{L \times D}$$&lt;br&gt;[128 words x 128 dims]" vertex="1">
          <mxGeometry height="70" width="220" x="2494" y="3490" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-192" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;2. Permutation (Dimensional Flip)&lt;/b&gt;&lt;br&gt;$$\mathbf{E}^\intercal \in \mathbb{R}^{D \times L}$$&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;The CNN treats D as &quot;Channels&quot; and&lt;br&gt;L as the &quot;Spatial Grid&quot;.&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="2484" y="3600" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-193" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;3. The Sliding Window (Kernel)&lt;/b&gt;&lt;br&gt;Learned Filter Matrix $$\mathbf{W} \in \mathbb{R}^{D \times K}$$&lt;br&gt;where $K$ (Kernel Size) = 3 words.&lt;br&gt;&lt;br&gt;Looking for local attack n-grams&lt;br&gt;(e.g., &quot;ignore&quot;, &quot;all&quot;, &quot;rules&quot;)" vertex="1">
          <mxGeometry height="100" width="280" x="2464" y="3720" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-194" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;4. Vectorized Dot-Product&lt;/b&gt;&lt;br&gt;At each step $t$:&lt;br&gt;$$z_t = \sum_{j=1}^K \mathbf{W}_j \cdot \mathbf{e}_{t+j} + b$$&lt;br&gt;&lt;br&gt;A local linear projection of a&lt;br&gt;3-word window into a single value." vertex="1">
          <mxGeometry height="110" width="240" x="2485" y="3915" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-195" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;5. Non-linear Activation&lt;/b&gt;&lt;br&gt;$$\mathbf{h}_t = \max(0, z_t)$$&lt;br&gt;&lt;br&gt;Filtering out &quot;Zero Signal&quot;&lt;br&gt;and introducing sparsity." vertex="1">
          <mxGeometry height="110" width="170" x="2520" y="4100" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-196" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;6. Feature Map Output&lt;/b&gt;&lt;br&gt;$$\mathbf{H}_{cnn} \in \mathbb{R}^{L \times D_{out}}$$&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;(Flipped back to sequence order)&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="220" x="2495" y="4300" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-197" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-191" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-192" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-198" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-192" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-193" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-199" edge="1" parent="1" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-194" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="2604.9999999999995" y="3875" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-200" edge="1" parent="1" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-195" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="2605" y="4060" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-201" edge="1" parent="1" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-196" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="2605" y="4260" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-202" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;The Algebraic view&lt;/b&gt;&lt;br&gt;Convolution is a&lt;br&gt;&lt;b&gt;Locally Connected&lt;/b&gt;&lt;br&gt;linear layer.&lt;br&gt;&lt;br&gt;Instead of word 1&lt;br&gt;looking at word 100,&lt;br&gt;word 1 only &lt;br&gt;communicates with its&lt;br&gt;nearest neighbors.&quot;" vertex="1">
          <mxGeometry height="180" width="180" x="2240" y="3840" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-203" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;The Signal view&lt;/b&gt;&lt;br&gt;This is identical to&lt;br&gt;filtering an audio wave.&lt;br&gt;We are &quot;smoothing&quot; the&lt;br&gt;embedding vectors&lt;br&gt;to find semantic &lt;br&gt;frequencies." vertex="1">
          <mxGeometry height="150" width="180" x="2790" y="3600" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-204" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" value="Algorithm: Bi-directional LSTM (Sequential Manifold Mapping)" vertex="1">
          <mxGeometry height="30" width="550" x="3780" y="3430" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-205" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;1. Enriched Feature Matrix&lt;/b&gt;&lt;br&gt;$$\mathbf{H}_{cnn} \in \mathbb{R}^{L \times D}$$&lt;br&gt;[Output from the CNN branch]" vertex="1">
          <mxGeometry height="70" width="220" x="3944" y="3480" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-206" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;2. Temporal Symmetry Split&lt;/b&gt;&lt;br&gt;The signal is cloned into two&lt;br&gt;independent Recurrent Operators." vertex="1">
          <mxGeometry height="60" width="260" x="3924" y="3590" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-207" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Forward Path&lt;/b&gt; $(\overrightarrow{f})$&lt;br&gt;$$x_1 \to x_2 \to \dots \to x_L$$&lt;br&gt;Captures &quot;Causal&quot; Context" vertex="1">
          <mxGeometry height="70" width="210" x="3780" y="3690" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-208" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Backward Path&lt;/b&gt; $(\overleftarrow{f})$&lt;br&gt;$$x_L \to x_{L-1} \to \dots \to x_1$$&lt;br&gt;Captures &quot;Anticipatory&quot; Context" vertex="1">
          <mxGeometry height="70" width="210" x="4120" y="3690" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-209" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;3. Internal Gating Algebra&lt;/b&gt;&lt;br&gt;&lt;br&gt;$$f_t = \sigma(W_f [h_{t-1}, x_t] + b_f) \quad \text{(Forget)}$$&lt;br&gt;$$i_t = \sigma(W_i [h_{t-1}, x_t] + b_i) \quad \text{(Input)}$$&lt;br&gt;$$o_t = \sigma(W_o [h_{t-1}, x_t] + b_o) \quad \text{(Output)}$$&lt;br&gt;&lt;br&gt;$$c_t = f_t \odot c_{t-1} + i_t \odot \tanh(\dots) \quad \text{(Cell state)}$$" vertex="1">
          <mxGeometry height="150" width="310" x="3899" y="3800" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-210" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;4. Hidden State Fusion&lt;/b&gt;&lt;br&gt;$$\mathbf{h}_{total} = [ \overrightarrow{h}_t \oplus \overleftarrow{h}_t ]$$&lt;br&gt;$$\mathbf{h}_{total} \in \mathbb{R}^{L \times 256}$$&lt;br&gt;Concatenating past and future&lt;br&gt;manifolds at every time step $t$." vertex="1">
          <mxGeometry height="200" width="200" x="3954" y="3990" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-211" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" value="&lt;b&gt;5. Sequential Manifold Matrix&lt;/b&gt;&lt;br&gt;Ready for Global Attention Analysis" vertex="1">
          <mxGeometry height="60" width="260" x="3924" y="4230" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-212" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-205" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-206" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-213" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-206" style="endArrow=classic;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-207" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <Array as="points">
              <mxPoint x="3885" y="3650" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-214" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-206" style="endArrow=classic;html=1;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-208" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <Array as="points">
              <mxPoint x="4225" y="3650" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-215" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-207" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-209" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <Array as="points">
              <mxPoint x="3885" y="3875" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-216" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-208" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-209" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <Array as="points">
              <mxPoint x="4225" y="3875" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-217" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-209" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-210" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-218" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-210" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-211" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-219" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Markovian Flow&lt;/b&gt;&lt;br&gt;Each state $h_t$ is a&lt;br&gt;recursive function of&lt;br&gt;the word AND the &lt;br&gt;history. It turns static&lt;br&gt;points into a &lt;br&gt;&lt;b&gt;Trajectory&lt;/b&gt;." vertex="1">
          <mxGeometry height="150" width="180" x="3670" y="3780" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-220" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;The Gate Logic&lt;/b&gt;&lt;br&gt;Gates are &lt;i&gt;masks&lt;/i&gt; in &lt;br&gt;$[0, 1]^d$.&lt;br&gt;The &lt;b&gt;Forget Gate&lt;/b&gt; &lt;br&gt;decides how much of &lt;br&gt;the previous trajectory &lt;br&gt;remains relevant for&lt;br&gt;the current word." vertex="1">
          <mxGeometry height="170" width="180" x="4250" y="3790" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-221" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Integration Logic&lt;/b&gt;&lt;br&gt;By the time we reach &lt;br&gt;the Attention layer,&lt;br&gt;every word vector &lt;br&gt;contains a &quot;Global &lt;br&gt;Scent&quot; from both sides&lt;br&gt;of the sentence." vertex="1">
          <mxGeometry height="160" width="180" x="3690" y="4020" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-222" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" value="Algorithm: Self-Attention (Global Interaction Graph)" vertex="1">
          <mxGeometry height="30" width="440" x="5460" y="3410" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-223" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;1. Sequential Manifold Matrix&lt;/b&gt;&lt;br&gt;$$\mathbf{H}_{lstm} \in \mathbb{R}^{L \times 256}$$&lt;br&gt;[Output from the BiLSTM branch]" vertex="1">
          <mxGeometry height="70" width="220" x="5574" y="3460" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-224" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;2. Latent Subspace Projections&lt;/b&gt;&lt;br&gt;Mapping the manifold into three distinct roles:&lt;br&gt;&lt;br&gt;$$\mathbf{Q} = \mathbf{H} \mathbf{W}_q \quad \text{(Queries: &quot;What am I looking for?&quot;)}$$&lt;br&gt;$$\mathbf{K} = \mathbf{H} \mathbf{W}_k \quad \text{(Keys: &quot;What content do I have?&quot;)}$$&lt;br&gt;$$\mathbf{V} = \mathbf{H} \mathbf{W}_v \quad \text{(Values: &quot;What signal do I pass?&quot;)}$$" vertex="1">
          <mxGeometry height="120" width="320" x="5524" y="3570" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-225" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;3. The Interaction Kernel (Dot-Product)&lt;/b&gt;&lt;br&gt;$$\text{Score} = \mathbf{Q} \mathbf{K}^\intercal$$&lt;br&gt;&lt;br&gt;An $L \times L$ matrix measuring the &lt;br&gt;alignment between all token pairs." vertex="1">
          <mxGeometry height="90" width="300" x="5534" y="3730" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-226" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;4. Normalization &amp;amp; Softmax Mask&lt;/b&gt;&lt;br&gt;$$\mathbf{A} = \text{Softmax} \left( \frac{\text{Score}}{\sqrt{d_k}} \right)$$&lt;br&gt;&lt;br&gt;Converting similarity scores into a&lt;br&gt;Probability Distribution (Weights)." vertex="1">
          <mxGeometry height="140" width="200" x="5584" y="3860" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-227" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;5. Weighted Signal Aggregation&lt;/b&gt;&lt;br&gt;$$\mathbf{Z} = \mathbf{A} \mathbf{V}$$&lt;br&gt;&lt;br&gt;Summing the &quot;Values&quot; based on&lt;br&gt;the importance weights in matrix A." vertex="1">
          <mxGeometry height="90" width="230" x="5569" y="4040" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-228" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" value="&lt;b&gt;6. Attended Logic Matrix&lt;/b&gt;&lt;br&gt;$$\mathbf{Z} \in \mathbb{R}^{L \times 256}$$&lt;br&gt;Ready for Centroid/Pooling Collapse" vertex="1">
          <mxGeometry height="70" width="220" x="5574" y="4170" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-229" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-223" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-224" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-230" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-224" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-225" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-231" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-225" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-226" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-232" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-226" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-227" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-233" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-227" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-228" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-234" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;The Topological View&lt;/b&gt;&lt;br&gt;Convolution is a &lt;b&gt;Line&lt;/b&gt;.&lt;br&gt;LSTM is a &lt;b&gt;Chain&lt;/b&gt;.&lt;br&gt;Attention is a &lt;b&gt;Graph&lt;/b&gt;.&lt;br&gt;&lt;br&gt;It allows the word &lt;i&gt;&quot;Ignore&quot;&lt;/i&gt;&lt;br&gt;at index 1 to communicate&lt;br&gt;directly with &lt;i&gt;&quot;Instructions&quot;&lt;/i&gt;&lt;br&gt;at index 120." vertex="1">
          <mxGeometry height="190" width="180" x="5320" y="3720" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-235" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Dynamic Filtering&lt;/b&gt;&lt;br&gt;Unlike the CNN, where &lt;br&gt;weights are fixed after &lt;br&gt;training, Attention weights&lt;br&gt;are &lt;b&gt;calculated on the fly&lt;/b&gt;&lt;br&gt;based on the input itself.&lt;br&gt;&lt;br&gt;This makes it much&lt;br&gt;harder to bypass.&quot;" vertex="1">
          <mxGeometry height="170" width="180" x="5860" y="3845" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-236" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" value="Algorithm: Global Centroid Projection (The Many-to-One Mapping)" vertex="1">
          <mxGeometry height="30" width="580" x="6910" y="3420" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-237" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;1. High-Rank Feature Manifold&lt;/b&gt;&lt;br&gt;$$\mathbf{Z} \in \mathbb{R}^{L \times D}$$&lt;br&gt;&lt;br&gt;A stack of $128$ vectors ($L$),&lt;br&gt;each containing $256$ refined &lt;br&gt;mathematical perspectives ($D$)." vertex="1">
          <mxGeometry height="100" width="220" x="7094" y="3470" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-238" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;2. Accumulation (Summation)&lt;/b&gt;&lt;br&gt;$$\mathbf{S} = \sum_{i=1}^{L} \mathbf{z}_i$$&lt;br&gt;&lt;br&gt;Merging all token positions into&lt;br&gt;a single aggregate feature set." vertex="1">
          <mxGeometry height="90" width="220" x="7094" y="3600" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-239" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;3. Normalization (Scaling)&lt;/b&gt;&lt;br&gt;$$\mathbf{y} = \frac{1}{L} \cdot \mathbf{S}$$&lt;br&gt;&lt;br&gt;Dividing by the sequence length&lt;br&gt;to find the &lt;b&gt;Average Semantic Energy&lt;/b&gt;." vertex="1">
          <mxGeometry height="90" width="270" x="7069" y="3720" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-240" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" value="&lt;b&gt;4. The Sentence Centroid&lt;/b&gt;&lt;br&gt;$$\mathbf{y} \in \mathbb{R}^{1 \times D}$$&lt;br&gt;&lt;br&gt;The &quot;Center of Mass&quot; of the prompt&lt;br&gt;in the 256-dimensional concept space." vertex="1">
          <mxGeometry height="90" width="250" x="7079" y="3850" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-241" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;5. Decision Boundary Analysis&lt;/b&gt;&lt;br&gt;This vector is now compared against&lt;br&gt;the learned Hyperplane ($fc$ layer).&lt;br&gt;&lt;br&gt;$$\text{Verdict} = f(\mathbf{y})$$" vertex="1">
          <mxGeometry height="120" width="200" x="7104" y="3980" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-242" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-237" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-238" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-243" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-238" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-239" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-244" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-239" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-240" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-245" edge="1" parent="1" source="Zet76qL6K-UuKe0f87bM-240" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" target="Zet76qL6K-UuKe0f87bM-241" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-246" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Positional Invariance&lt;/b&gt;&lt;br&gt;Mathematically, the mean &lt;br&gt;does not care if the &lt;br&gt;malicious intent was &lt;br&gt;at word 1 or word 128.&lt;br&gt;&lt;br&gt;If the &lt;b&gt;Total Mass&lt;/b&gt; of the &lt;br&gt;vectors shifts toward &lt;br&gt;the &quot;Attack&quot; region, the &lt;br&gt;Centroid will follow." vertex="1">
          <mxGeometry height="200" width="190" x="6840" y="3645" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-247" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Manifold Compression&lt;/b&gt;&lt;br&gt;We have successfully &lt;br&gt;mapped a 2D surface &lt;br&gt;(Sentence Matrix) &lt;br&gt;onto a 1D Coordinate &lt;br&gt;(Sentence Identity).&lt;br&gt;&lt;br&gt;Rank: 2 → Rank: 1" vertex="1">
          <mxGeometry height="150" width="180" x="7370" y="3850" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-248" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" value="Algorithm: Self-Healing Prompt Defense Engine (SHPDE)" vertex="1">
          <mxGeometry height="30" width="520" x="8620" y="3390" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-249" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;1. Probability Input&lt;/b&gt;&lt;br&gt;$$\hat{P} = \text{DP-IDN}(S_{user})$$&lt;br&gt;$$\hat{P} \in [0, 1]$$" vertex="1">
          <mxGeometry height="90" width="170" x="8799" y="3440" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-250" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;2. Threshold Decision&lt;/b&gt;&lt;br&gt;$$\text{Decision} = \mathbb{I}(\hat{P} &gt; \tau)$$&lt;br&gt;where $\tau = 0.5$" vertex="1">
          <mxGeometry height="150" width="210" x="8779" y="3560" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-251" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;Safe Protocol&lt;/b&gt;&lt;br&gt;$$S_{final} = S_{user}$$&lt;br&gt;Direct Forwarding" vertex="1">
          <mxGeometry height="60" width="160" x="8570" y="3605" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-252" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;3. Diagnosis Function&lt;/b&gt;&lt;br&gt;$$\mathcal{D}(S_{user}) \to \text{Category } C$$&lt;br&gt;Identify attack signature&lt;br&gt;(Extraction, Roleplay, etc.)" vertex="1">
          <mxGeometry height="80" width="210" x="8779" y="3760" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-253" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;4. Patch Retrieval&lt;/b&gt;&lt;br&gt;Select reinforcement vector $\mathbf{p} \in \mathcal{K}$&lt;br&gt;where $\mathcal{K}$ is the Defense Knowledge Base." vertex="1">
          <mxGeometry height="80" width="280" x="8744" y="3880" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-254" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" value="&lt;b&gt;5. The &quot;Healing&quot; Concatenation&lt;/b&gt;&lt;br&gt;$$S_{healed} = S_{system} \oplus \text{ALERT} \oplus \mathbf{p} \oplus S_{user}$$&lt;br&gt;&lt;br&gt;Synthesizing an &quot;Armored Context&quot; for the LLM." vertex="1">
          <mxGeometry height="90" width="310" x="8729" y="4000" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-255" parent="1" style="shape=module;align=left;spacingLeft=20;adjustableCurve=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Target LLM (Transformer)&lt;/b&gt;&lt;br&gt;Processes the reinforced instructions&lt;br&gt;guaranteeing safe output survival." vertex="1">
          <mxGeometry height="80" width="200" x="8784" y="4130" as="geometry" />
        </mxCell>
