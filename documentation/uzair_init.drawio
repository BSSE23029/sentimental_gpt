          </mxGeometry>
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-263" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Defense Survival Logic&lt;/b&gt;&lt;br&gt;We don&#39;t block the user&lt;br&gt;blindly. We &lt;b&gt;Heal&lt;/b&gt; the &lt;br&gt;input so the LLM knows &lt;br&gt;exactly what rule is &lt;br&gt;currently under attack.&lt;br&gt;&lt;br&gt;This maximizes &lt;br&gt;&lt;i&gt;Service Availability&lt;/i&gt;." vertex="1">
          <mxGeometry height="190" width="200" x="8510" y="3800" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-264" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Mathematical Fusion&lt;/b&gt;&lt;br&gt;The final prompt is a &lt;br&gt;&lt;b&gt;Set Union&lt;/b&gt; of the &lt;br&gt;User&#39;s Intent and the &lt;br&gt;System&#39;s Defense.&lt;br&gt;&lt;br&gt;By the time it hits the&lt;br&gt;LLM, the malicious &lt;br&gt;gravity is balanced &lt;br&gt;by the defense energy.&quot;" vertex="1">
          <mxGeometry height="200" width="190" x="9060" y="3960" as="geometry" />
        </mxCell>
        <mxCell id="Zet76qL6K-UuKe0f87bM-265" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" value="SHPDE Gap Analysis: Mapping the Adversarial Leakage" vertex="1">
